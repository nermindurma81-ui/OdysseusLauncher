<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/od_bg">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/od_red"
        android:visibility="visible" />

    <!-- Nice launch / control screen -->
    <ScrollView
        android:id="@+id/errorView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡"
                android:textSize="48sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/od_white"
                android:textSize="30sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tagline"
                android:textColor="@color/od_fg_dim"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="28dp" />

            <!-- Status card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_status_card"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/errorText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/connection_error_default"
                    android:textColor="@color/od_fg"
                    android:textSize="14sp"
                    android:gravity="center" />
            </LinearLayout>


                <LinearLayout
                    android:id="@+id/startupProgressPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/startupProgressText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/startup_progress_idle"
                        android:textColor="@color/od_fg"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <ProgressBar
                        android:id="@+id/startupProgressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="3"
                        android:progress="0"
                        android:progressTint="@color/od_green"
                        android:progressBackgroundTint="@color/od_border" />
                </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/startNineRouterButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="@string/start_nine_router"
                android:textSize="16sp"
                app:backgroundTint="@color/od_panel_light"
                app:strokeColor="@color/od_border"
                app:strokeWidth="1dp"
                app:cornerRadius="14dp"
                android:textColor="@color/od_white"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/startServersButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="@string/start_servers"
                android:textSize="16sp"
                app:backgroundTint="@color/od_red"
                app:cornerRadius="14dp"
                android:textColor="@color/od_white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/retryButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="28dp"
                android:text="@string/retry"
                android:textSize="15sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/od_fg_dim"
                app:cornerRadius="14dp"
                android:textColor="@color/od_fg" />

            <TextView
                android:id="@+id/debugLogButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_log_button"
                android:textColor="@color/od_fg_dim"
                android:textSize="13sp"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground" />

        </LinearLayout>
    </ScrollView>

    <!-- Small persistent debug button visible even while WebView is showing -->
    <TextView
        android:id="@+id/debugLogFloatingButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="🐞"
        android:textSize="20sp"
        android:padding="10dp"
        android:background="@drawable/bg_fab_debug"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

</FrameLayout>
