<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/navy_deep" android:padding="16dp">
    <LinearLayout android:id="@+id/loadingView" android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#80000000" android:gravity="center" android:visibility="gone" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pokretam servise..."
            android:textColor="@color/gold" android:textSize="20sp" android:textStyle="bold" />
        <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp"
            android:indeterminate="true" android:indeterminateTint="@color/gold" />
    </LinearLayout>
    <LinearLayout android:id="@+id/errorView" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center" android:visibility="gone" android:orientation="vertical">
        <TextView android:id="@+id/errorText" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/error_red" android:textSize="16sp" />
        <Button android:id="@+id/retryButton" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:text="Pokušaj ponovo" android:backgroundTint="@color/gold" android:textColor="@color/navy_deep" />
    </LinearLayout>
    <ScrollView android:id="@+id/mainContent" android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
            <Button android:id="@+id/btn9Router" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:text="Pokreni 9Router" android:backgroundTint="@color/navy_mid" android:textColor="@color/gold" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="4dp">
                <ImageView android:id="@+id/statusDot9Router" android:layout_width="12dp" android:layout_height="12dp"
                    android:src="@drawable/status_dot" android:layout_marginEnd="8dp" />
                <TextView android:id="@+id/statusText9Router" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Nije pokrenut" android:textColor="@color/pending_gray" />
            </LinearLayout>
            <Button android:id="@+id/btnServers" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:layout_marginBottom="8dp" android:text="Pokreni Servere" android:backgroundTint="@color/navy_mid" android:textColor="@color/gold" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="4dp">
                <ImageView android:id="@+id/statusDotServers" android:layout_width="12dp" android:layout_height="12dp"
                    android:src="@drawable/status_dot" android:layout_marginEnd="8dp" />
                <TextView android:id="@+id/statusTextServers" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Nije pokrenut" android:textColor="@color/pending_gray" />
            </LinearLayout>
            <Button android:id="@+id/btnOdysseus" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:layout_marginBottom="8dp" android:text="Pokreni Odysseus" android:backgroundTint="@color/navy_mid" android:textColor="@color/gold" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="4dp">
                <ImageView android:id="@+id/statusDotOdysseus" android:layout_width="12dp" android:layout_height="12dp"
                    android:src="@drawable/status_dot" android:layout_marginEnd="8dp" />
                <TextView android:id="@+id/statusTextOdysseus" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Nije pokrenut" android:textColor="@color/pending_gray" />
            </LinearLayout>
            <WebView android:id="@+id/webView" android:layout_width="match_parent" android:layout_height="match_parent"
                android:layout_marginTop="16dp" android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
